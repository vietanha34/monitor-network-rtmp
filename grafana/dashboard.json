      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "deriv(netrtmp_connection_packets{hostname=~\"$hostname\", dest_ip=~\"$dest_ip\", direction=\"received\"}[2m])",
          "legendFormat": "{{dest_ip}}:{{local_port}}",
          "refId": "A"
