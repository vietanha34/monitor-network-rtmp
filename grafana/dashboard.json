      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Active Connections per Destination (stacked)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "netrtmp_connections_active{hostname=~\"$hostname\", dest_ip=~\"$dest_ip\"}",
          "legendFormat": "{{dest_ip}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Sent Bytes" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.width", "value": 130 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Recv Bytes" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.width", "value": 130 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Sent Pkts" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Recv Pkts" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.width", "value": 110 }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "id": 21,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Sent Bytes" }]
      },
      "title": "Live Connection Table",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "dest_port": false, "__name__": true },
            "renameByName": {
              "dest_ip": "Dest IP",
              "dest_port": "Port",
              "local_port": "Local Port",
              "Value #sent": "Sent Bytes",
              "Value #received": "Recv Bytes",
              "Value #segs_out": "Sent Pkts",
              "Value #segs_in": "Recv Pkts"
            }
          }
        }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "netrtmp_connection_bytes{hostname=~\"$hostname\", dest_ip=~\"$dest_ip\", direction=\"sent\"}",
          "legendFormat": "sent",
          "refId": "sent",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "netrtmp_connection_bytes{hostname=~\"$hostname\", dest_ip=~\"$dest_ip\", direction=\"received\"}",
          "legendFormat": "received",
          "refId": "received",
          "instant": true
        }
      ]
    },
